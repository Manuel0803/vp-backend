{
  "kind": "collectionType",
  "collectionName": "news",
  "info": {
    "singularName": "new",
    "pluralName": "news",
    "displayName": "news"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "text",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "blocks"
    },
    "region": {
      "type": "enumeration",
      "enum": [
        "ARGENTINA",
        "CHACO",
        "CORRIENTES"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "RIGHTS",
        "HEALTH_PREVENTION",
        "WELLBEING",
        "ACTIVE_LIVING",
        "CARE_FAMILY",
        "COMMUNITY",
        "CULTURE_LEARNING",
        "SERVICES_PROCEDURES",
        "CURRENTS_AFFAIRS"
      ]
    },
    "target_audience": {
      "type": "enumeration",
      "enum": [
        "OLDER_PEOPLE",
        "FAMILY",
        "PROFESIONAL",
        "ALL"
      ]
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "news"
    },
    "published_date": {
      "type": "datetime"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
