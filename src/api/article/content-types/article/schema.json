{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "blocks"
    },
    "published_date": {
      "type": "datetime"
    },
    "article_type": {
      "type": "enumeration",
      "enum": [
        "INFORMACION_PRACTICA",
        "ENTREVISTA",
        "OPINION",
        "INFORME",
        "HISTORIA",
        "AGENDA",
        "RECURSOS"
      ]
    },
    "target_audience": {
      "type": "enumeration",
      "enum": [
        "OLDER_PEOPLE",
        "FAMILY",
        "PROFESIONAL",
        "ALL"
      ]
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Gestión de la Dependencia",
        "Trámites y Derechos",
        "Salud y Bienestar",
        "Participación y Cultura",
        "Residencias",
        "Vida Social",
        "Marco Normativo",
        "Actualidad Profesional"
      ]
    },
    "hub": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::content-hub.content-hub",
      "inversedBy": "articles"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
