{
  "kind": "collectionType",
  "collectionName": "useful_phones",
  "info": {
    "singularName": "useful-phone",
    "pluralName": "useful-phones",
    "displayName": "useful_phone"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "PUBLIC_SERVICES",
        "EMERGENCY",
        "PUBLIC_HEALTH",
        "IMPORTANT"
      ]
    },
    "priority": {
      "type": "integer",
      "required": true
    },
    "province": {
      "type": "enumeration",
      "enum": [
        "CHACO",
        "CORRIENTES"
      ]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "tag": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "URGENCIA",
        "ATENCION_24_HRS"
      ]
    }
  }
}
