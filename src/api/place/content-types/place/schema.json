{
  "kind": "collectionType",
  "collectionName": "places",
  "info": {
    "singularName": "place",
    "pluralName": "places",
    "displayName": "place"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "COMMUNITY_LIBRARIES",
        "SENIOR_CENTERS",
        "WORKSHOPS",
        "HEALTH_CENTER"
      ]
    },
    "province": {
      "type": "enumeration",
      "enum": [
        "CHACO",
        "CORRIENTES"
      ]
    },
    "city": {
      "type": "enumeration",
      "enum": [
        "RESISTENCIA",
        "CORRIENTES",
        "BARRANQUERAS",
        "SANTA_ANA"
      ]
    },
    "address": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "latitude": {
      "type": "float"
    },
    "longitude": {
      "type": "float"
    },
    "is_active": {
      "type": "boolean",
      "default": false
    },
    "schedule": {
      "type": "string"
    }
  }
}
