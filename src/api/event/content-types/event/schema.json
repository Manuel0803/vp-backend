{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "blocks"
    },
    "event_type": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "Curso Virtual",
        "Congreso"
      ]
    },
    "modality": {
      "type": "enumeration",
      "enum": [
        "Virtual",
        "Presencial"
      ]
    },
    "start_date": {
      "type": "datetime"
    },
    "end_date": {
      "type": "datetime"
    },
    "location": {
      "type": "string"
    },
    "organizer": {
      "type": "string"
    },
    "target_audience": {
      "type": "enumeration",
      "enum": [
        "OLDER_PEOPLE",
        "FAMILY",
        "PROFESIONAL",
        "ALL"
      ]
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "events"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "description": {
      "type": "text"
    }
  }
}
