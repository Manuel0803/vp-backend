{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "event_type": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "charla",
        "taller",
        "encuentro"
      ]
    },
    "modality": {
      "type": "enumeration",
      "enum": [
        "presencial",
        "virtual"
      ]
    },
    "start_date": {
      "type": "datetime"
    },
    "end_date": {
      "type": "datetime"
    },
    "location": {
      "type": "string"
    },
    "organizer": {
      "type": "string"
    },
    "target_audience": {
      "type": "enumeration",
      "enum": [
        "vejez",
        "familia",
        "profesionales"
      ]
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "events"
    }
  }
}
